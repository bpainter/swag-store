# Public base URL for the Vercel Swag Store API.
# Safe to expose to the client. Used by lib/api/client.ts.
NEXT_PUBLIC_API_URL=https://vercel-swag-store-api.vercel.app/api

# Server-only bypass token sent as `x-vercel-protection-bypass` on every API request.
# NEVER reference from a client component. Validated at boot in lib/env.ts.
SWAG_BYPASS_TOKEN=
